[
    {
        "guidance": "1. Employees: Query your own salary data only via ask_for_salary tool",
        "action": "ask_for_salary",
        "common_constraints": [
            "user is an employee"
        ],
        "allow_conditions": [
            "employee queries their own salary data"
        ],
        "disallow_conditions": [
            "employee queries other employees' salary data"
        ],
        "system_variables": [
            "user_role"
        ],
        "prompt_variables": [
            "query_target (string)"
        ]
    },
    {
        "guidance": "2. Managers: View only the requested manager's team compensation data (employee name, title, salary, bonus, department, hire date) via view_team_compensation tool",
        "action": "view_team_compensation",
        "common_constraints": [
            "user is a manager"
        ],
        "allow_conditions": [
            "manager views their own team's compensation data",
            "data includes employee name, title, salary, bonus, department, hire date"
        ],
        "disallow_conditions": [
            "manager views other managers' team compensation data"
        ],
        "system_variables": [
            "user_role",
            "user_team"
        ],
        "prompt_variables": [
            "requested_team (string)",
            "data_fields (list)"
        ]
    },
    {
        "guidance": "3. Employees cannot view team compensation data, bonus, or hire date information (view_team_compensation tool blocked)",
        "action": "view_team_compensation",
        "common_constraints": [
            "user is an employee"
        ],
        "allow_conditions": [],
        "disallow_conditions": [
            "employee views team compensation data",
            "employee views bonus information",
            "employee views hire date information"
        ],
        "system_variables": [
            "user_role"
        ],
        "prompt_variables": []
    },
    {
        "guidance": "4. Managers cannot see any team's Social Security Numbers (SSN), Home addresses, Bank account numbers, Tax ID numbers when querying salary infomation.",
