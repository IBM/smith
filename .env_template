# Project-specific configuration
BASE_URL=base url of your skill folder
DATA_DIR=assets/opa/
POLICY_DIR=assets/
POLICY_PATH=policy.rego

# Model configuration
MODEL_SONNET=GCP/claude-4-sonnet
TEMP=0.2
TOP_P=0.9
OPENAI_API_KEY=your api key
OPENAI_BASE_URL=your base url

# Target agent configuration
AGENT_URL=http://localhost:9000
RITS_MODEL=your rits model
RITS_BASE_URL=your rits base url
RITS_API_KEY=your rits api key
TARGET_AGENT_PATH=mcp_servers/your_mcp_server/
GUIDANCE_FILE=mcp_servers/your_mcp_server/smith/guidance.txt
SYSTEM_VAR_FILE=mcp_servers/your_mcp_server/smith/system_vars.json
PROMPTFOO_CONFIG_FILE=mcp_servers/your_mcp_server/smith/promptfooconfig.yaml
PROMPTFOO_OUTPUT_FILE=mcp_servers/your_mcp_server/smith/redteam1.yaml

## MCP settings: for get_mcp_parameters when generating the policy
MCP_TRANSPORT=sse
MCP_URL=http://localhost:8000/sse

# example for stdio MCP
# MCP_TRANSPORT=stdio
# MCP_COMMAND=python
# MCP_ARGS=server.py
# MCP_CWD=mcp_servers/call-for-papers-mcp

# example for nodejs MCP
# MCP_TRANSPORT=stdio
# MCP_COMMAND=node
# MCP_ARGS=dist/index.js
# MCP_CWD=mcp_servers/context7-mcp


# Policy testing configuration
BAD_COMMAND_PATH=references/test_cases/allow
BENIGN_COMMAND_PATH=references/test_cases/disallow
TEST_CASE_PATH=references/test_cases/
TEST_PATH=tests/integration/
TEST_RESULT_PATH=scorecard_summary.txt

# Test case generation configuration
TEST_CASE_TEMPLATE=references/test_case_template.json
TEST_GENERATION_PATH=scripts/test_generation/
DECOMP_FILE=references/decomp_file.json
FLATTEN_FILE=references/decomp_flatten_file.json
ATTACK_FILE_CSV=ares/assets/safety_behaviors_text_subset.csv
VARS_FILE=references/vars_file.json
ATTACK_FILE=references/decomp_attack_file.json
ATTACK_FILE_PROMPT=references/decomp_attack_file_promptfoo.json
CASE_FILE=references/test_cases.json
FINAL_TEST_CASES=references/test_cases/
GREY_GUIDANCE_FILE=references/grey_guidance.json

BATCH_PROCESSING=true
BATCH_SIZE=10
CASE_GENERATION_BATCH_SIZE=5

## Red teaming tool configuration
ARES_HOME=path to your ares project directory
PROMPTFOO_DISABLE_TELEMETRY=1


# Test case evaluation configuration
CLASSIFIED_PROMPTFOO_FILE=references/decomp_attack_file_promptfoo_classified.json
CLASSIFY_TOP_N=3


# Policy refinement configuration

## Patching agent configuration
BACKUP_NAME='tmp'
### for red feedback update
CLUSTER_RESULTS=cluster_results.txt
### DBSCAN clustering parameters for grouping similar test case failures
### EPS: maximum cosine distance between two samples to be in the same cluster (smaller = tighter clusters)
CLUSTER_EPS=0.3
### MIN_SAMPLES: minimum number of samples required to form a cluster (samples below this threshold become noise)
CLUSTER_MIN_SAMPLES=2

## Linting agent configuration
GRAPH_PATH=ast.dot
OPA_AST_PATH=ast.json
GRAPH_SUGGESTION_PATH=graph_suggestion.txt
### for duplication feedback update
MODIFIED_POLICY_DEDUPLICATE=deduplicate_policy.rego
### for regal feedback update
REGAL_RESULT_OUTPUT=regal_result_output.txt
MODIFIED_POLICY_REGAL=regal_policy.rego
REGAL_SUGGESTION_PATH=regal_suggestion.txt
